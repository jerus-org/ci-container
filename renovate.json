{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "schedule": [
    "* 0-5 3 * *"
  ],
  "extends": [
    "docker:pinDigests",
    "customManagers:dockerfileVersions",
    "github>jerusdp/renovate-config:default.json"
  ],
  "packageRules": [
    {
      "groupName": "ci-security-tools",
      "matchDatasources": ["crate"],
      "matchPackageNames": [
        "cargo-audit",
        "cargo-deny"
      ]
    },
    {
      "groupName": "ci-cargo-ecosystem",
      "matchDatasources": ["crate"],
      "matchPackageNames": [
        "cargo-expand",
        "cargo-fuzz",
        "cargo-llvm-cov",
        "cargo-nextest",
        "cargo-release",
        "circleci-junit-fix",
        "rsign2"
      ]
    },
    {
      "groupName": "ci-release-pipeline",
      "matchDatasources": ["crate"],
      "matchPackageNames": [
        "gen-changelog",
        "kdeets",
        "nextsv",
        "pcu"
      ]
    },
    {
      "groupName": "ci-domain-tools",
      "matchDatasources": ["crate"],
      "matchPackageNames": [
        "cull-gmail",
        "gen-orb-mcp"
      ]
    },
    {
      "groupName": "ci-wasm-tools",
      "matchDatasources": ["crate"],
      "matchPackageNames": [
        "wasm-pack",
        "wasmtime-cli"
      ]
    }
  ]
}
